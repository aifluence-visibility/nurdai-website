{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/images/og-social-tr.jpg",
      "headers": [{ "key": "Accept-Ranges", "value": "none" }]
    },
    {
      "source": "/assets/images/og-social-en.jpg",
      "headers": [{ "key": "Accept-Ranges", "value": "none" }]
    },
    {
      "source": "/llms.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    },
    {
      "source": "/llms-full.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ],
  "functions": {
    "api/contact.js": {
      "maxDuration": 10
    }
  }
}
