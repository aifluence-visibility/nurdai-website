{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/images/og-social-tr.jpg",
      "headers": [{ "key": "Accept-Ranges", "value": "none" }]
    },
    {
      "source": "/assets/images/og-social-en.jpg",
      "headers": [{ "key": "Accept-Ranges", "value": "none" }]
    }
  ],
  "functions": {
    "api/contact.js": {
      "maxDuration": 10
    }
  }
}
