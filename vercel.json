{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.nurdai.com" }],
      "destination": "https://nurdai.com/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "www.nurdai.com" }],
      "destination": "https://nurdai.com/:path+",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": true
    }
  ],
  "functions": {
    "api/contact.js": {
      "maxDuration": 10
    }
  }
}
